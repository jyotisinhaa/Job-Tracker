# Copy this file to .env and fill in your values (see README.md).
# .env is gitignored — never commit real secrets.

# Supabase → Project Settings → API
SUPABASE_URL=
SUPABASE_ANON_KEY=          # publishable / anon key (browser-safe)
SUPABASE_SERVICE_KEY=       # secret / service_role key (server-side only)

# Apify → Settings → Integrations → API token
APIFY_TOKEN=
